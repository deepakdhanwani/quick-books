<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="008-customer-type-business" author="quickbooks">
        <addColumn tableName="customers">
            <column name="customer_type" type="VARCHAR(20)"/>
            <column name="business_name" type="VARCHAR(255)"/>
            <column name="gst_number" type="VARCHAR(20)"/>
            <column name="business_details" type="TEXT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
