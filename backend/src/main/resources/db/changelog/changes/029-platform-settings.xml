<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="029-platform-settings" author="quickbooks">
        <createTable tableName="platform_settings">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_name" type="VARCHAR(255)"/>
            <column name="support_email" type="VARCHAR(255)"/>
            <column name="contact_email" type="VARCHAR(255)"/>
            <column name="mobile_number" type="VARCHAR(30)"/>
            <column name="website_url" type="VARCHAR(500)"/>
            <column name="address_line1" type="VARCHAR(255)"/>
            <column name="address_line2" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(120)"/>
            <column name="state" type="VARCHAR(120)"/>
            <column name="country" type="VARCHAR(120)"/>
            <column name="postal_code" type="VARCHAR(30)"/>
            <column name="smtp_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="smtp_host" type="VARCHAR(255)"/>
            <column name="smtp_port" type="INTEGER"/>
            <column name="smtp_username" type="VARCHAR(255)"/>
            <column name="smtp_password" type="VARCHAR(500)"/>
            <column name="smtp_from_email" type="VARCHAR(255)"/>
            <column name="smtp_from_name" type="VARCHAR(255)"/>
            <column name="smtp_use_tls" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="smtp_use_ssl" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <insert tableName="platform_settings">
            <column name="id" valueNumeric="1"/>
            <column name="smtp_enabled" valueBoolean="false"/>
            <column name="smtp_use_tls" valueBoolean="true"/>
            <column name="smtp_use_ssl" valueBoolean="false"/>
            <column name="smtp_port" valueNumeric="587"/>
        </insert>
    </changeSet>

</databaseChangeLog>
