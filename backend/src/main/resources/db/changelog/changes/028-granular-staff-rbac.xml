            <column name="reminders_delete" type="BOOLEAN" defaultValueBoolean="false"><constraints nullable="false"/></column>
        </addColumn>

        <sql>
            UPDATE subscriber_users SET
                companies_create = can_manage_companies,
                companies_edit = can_manage_companies,
                companies_delete = can_manage_companies,
                customers_view = can_manage_customers,
                customers_create = can_manage_customers,
                customers_edit = can_manage_customers,
                customers_delete = can_manage_customers,
                vendors_view = can_manage_vendors,
                vendors_create = can_manage_vendors,
                vendors_edit = can_manage_vendors,
                vendors_delete = can_manage_vendors,
                sales_view = can_manage_sales,
                sales_create = can_manage_sales,
                sales_edit = can_manage_sales,
                sales_delete = can_manage_sales,
                purchases_view = can_manage_purchases,
                purchases_create = can_manage_purchases,
                purchases_edit = can_manage_purchases,
                purchases_delete = can_manage_purchases,
                products_view = can_manage_products,
