            <column name="purchases_create" type="BOOLEAN" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="purchases_edit" type="BOOLEAN" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="purchases_delete" type="BOOLEAN" defaultValueBoolean="false"><constraints nullable="false"/></column>
