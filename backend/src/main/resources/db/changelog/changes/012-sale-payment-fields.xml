<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="012-sale-invoice-fields" author="quickbooks">
        <addColumn tableName="sales">
            <column name="invoice_number" type="VARCHAR(100)"/>
            <column name="invoice_details" type="TEXT"/>
            <column name="gross_amount" type="DECIMAL(12,2)"/>
            <column name="discount_amount" type="DECIMAL(12,2)" defaultValueNumeric="0"/>
            <column name="tax_percent" type="DECIMAL(8,2)"/>
            <column name="tax_amount" type="DECIMAL(12,2)" defaultValueNumeric="0"/>
        </addColumn>
    </changeSet>

    <changeSet id="012-payment-mode-proof" author="quickbooks">
        <addColumn tableName="payments">
            <column name="payment_mode" type="VARCHAR(20)"/>
            <column name="payment_details" type="TEXT"/>
            <column name="proof_file_name" type="VARCHAR(255)"/>
            <column name="proof_file_path" type="VARCHAR(500)"/>
            <column name="proof_content_type" type="VARCHAR(100)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
