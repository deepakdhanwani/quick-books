<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="018-audit-logs" author="quickbooks">
        <createTable tableName="audit_logs">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscriber_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="actor_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="actor_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="actor_name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="actor_pin" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="BIGINT"/>
            <column name="details" type="VARCHAR(500)"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="audit_logs"
                baseColumnNames="subscriber_id"
                referencedTableName="subscribers"
                referencedColumnNames="id"
                constraintName="fk_audit_logs_subscriber"/>

        <createIndex tableName="audit_logs" indexName="idx_audit_logs_subscriber_created">
            <column name="subscriber_id"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
