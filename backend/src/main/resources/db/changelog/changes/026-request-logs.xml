<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="026-request-logs" author="quickbooks">
        <createTable tableName="request_logs">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="method" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="path" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="query_string" type="VARCHAR(1000)"/>
            <column name="status_code" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="duration_ms" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="client_ip" type="VARCHAR(45)"/>
            <column name="user_role" type="VARCHAR(20)"/>
            <column name="subscriber_id" type="BIGINT"/>
            <column name="subscriber_name" type="VARCHAR(200)"/>
            <column name="company_id" type="BIGINT"/>
            <column name="company_name" type="VARCHAR(200)"/>
            <column name="actor_name" type="VARCHAR(120)"/>
            <column name="actor_type" type="VARCHAR(20)"/>
        </createTable>

        <createIndex tableName="request_logs" indexName="idx_request_logs_created_at">
            <column name="created_at"/>
        </createIndex>

        <createIndex tableName="request_logs" indexName="idx_request_logs_subscriber_created">
            <column name="subscriber_id"/>
            <column name="created_at"/>
        </createIndex>

        <createIndex tableName="request_logs" indexName="idx_request_logs_status_created">
            <column name="status_code"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
