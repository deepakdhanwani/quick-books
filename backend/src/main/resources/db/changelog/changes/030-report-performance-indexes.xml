<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="030-report-performance-indexes" author="quickbooks">
        <createIndex tableName="sales" indexName="idx_sales_subscriber_company_date">
            <column name="subscriber_id"/>
            <column name="company_id"/>
            <column name="date"/>
        </createIndex>
        <createIndex tableName="purchases" indexName="idx_purchases_subscriber_company_date">
            <column name="subscriber_id"/>
            <column name="company_id"/>
            <column name="date"/>
        </createIndex>
        <createIndex tableName="payment_reminders" indexName="idx_reminders_subscriber_company_status_date">
            <column name="subscriber_id"/>
            <column name="company_id"/>
            <column name="status"/>
            <column name="promised_date"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
