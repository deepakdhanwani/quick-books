<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-admins" author="quickbooks">
        <createTable tableName="admins">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-subscribers" author="quickbooks">
        <createTable tableName="subscribers">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="business_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone" type="VARCHAR(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="login_pin_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="business_type" type="VARCHAR(100)"/>
            <column name="subscription_status" type="VARCHAR(20)" defaultValue="NONE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-subscription-plans" author="quickbooks">
        <createTable tableName="subscription_plans">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="duration" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-taxes" author="quickbooks">
        <createTable tableName="taxes">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="rate" type="DECIMAL(5,2)">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="tax_plans">
            <column name="tax_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_tax_plans_tax" references="taxes(id)"/>
            </column>
            <column name="plan_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_tax_plans_plan" references="subscription_plans(id)"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="tax_plans" columnNames="tax_id, plan_id"/>
    </changeSet>

    <changeSet id="005-discounts" author="quickbooks">
        <createTable tableName="discounts">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="scope" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="valid_from" type="DATE"/>
            <column name="valid_to" type="DATE"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="discount_subscribers">
            <column name="discount_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_discount_subscribers_discount" references="discounts(id)"/>
            </column>
            <column name="subscriber_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_discount_subscribers_subscriber" references="subscribers(id)"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="discount_subscribers" columnNames="discount_id, subscriber_id"/>
    </changeSet>

    <changeSet id="006-subscriber-subscriptions" author="quickbooks">
        <createTable tableName="subscriber_subscriptions">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscriber_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_sub_subscriber" references="subscribers(id)"/>
            </column>
            <column name="plan_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_sub_plan" references="subscription_plans(id)"/>
            </column>
            <column name="discount_id" type="BIGINT">
                <constraints foreignKeyName="fk_sub_discount" references="discounts(id)"/>
            </column>
            <column name="tax_amount" type="DECIMAL(12,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="007-customers-vendors" author="quickbooks">
        <createTable tableName="customers">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscriber_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_customer_subscriber" references="subscribers(id)"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="address" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="vendors">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscriber_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_vendor_subscriber" references="subscribers(id)"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="address" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="008-sales-purchases" author="quickbooks">
        <createTable tableName="sales">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscriber_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_sale_subscriber" references="subscribers(id)"/>
            </column>
            <column name="customer_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_sale_customer" references="customers(id)"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="paid_amount" type="DECIMAL(12,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="pending_amount" type="DECIMAL(12,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="payment_status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="purchases">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscriber_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_purchase_subscriber" references="subscribers(id)"/>
            </column>
            <column name="vendor_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_purchase_vendor" references="vendors(id)"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="paid_amount" type="DECIMAL(12,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="pending_amount" type="DECIMAL(12,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="payment_status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="sale_items">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sale_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_sale_item_sale" references="sales(id)" deleteCascade="true"/>
            </column>
            <column name="description" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="unit_price" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="purchase_items">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="purchase_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_purchase_item_purchase" references="purchases(id)" deleteCascade="true"/>
            </column>
            <column name="description" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="unit_price" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="009-payments" author="quickbooks">
        <createTable tableName="payments">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscriber_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_payment_subscriber" references="subscribers(id)"/>
            </column>
            <column name="type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="reference_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="reference_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
