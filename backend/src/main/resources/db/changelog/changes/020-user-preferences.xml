<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="020-user-preferences" author="quickbooks">
        <addColumn tableName="subscribers">
            <column name="theme_mode" type="VARCHAR(20)" defaultValue="DARK">
                <constraints nullable="false"/>
            </column>
            <column name="font_size" type="VARCHAR(20)" defaultValue="SMALL">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="subscriber_users">
            <column name="theme_mode" type="VARCHAR(20)" defaultValue="DARK">
                <constraints nullable="false"/>
            </column>
            <column name="font_size" type="VARCHAR(20)" defaultValue="SMALL">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
