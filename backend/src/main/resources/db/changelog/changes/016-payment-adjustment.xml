<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="016-payment-adjustment" author="quickbooks">
        <addColumn tableName="sales">
            <column name="adjusted_amount" type="DECIMAL(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="purchases">
            <column name="adjusted_amount" type="DECIMAL(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="payments">
            <column name="adjusted_amount" type="DECIMAL(19,2)"/>
            <column name="settlement_type" type="VARCHAR(20)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
