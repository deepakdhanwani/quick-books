<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="005-discount-plans" author="quickbooks">
        <createTable tableName="discount_plans">
            <column name="discount_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_discount_plans_discount" references="discounts(id)"/>
            </column>
            <column name="plan_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_discount_plans_plan" references="subscription_plans(id)"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="discount_plans" columnNames="discount_id, plan_id"/>
    </changeSet>

</databaseChangeLog>
