# Server
SERVER_PORT=9090

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quickbooks
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Spring Boot datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/quickbooks
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password_here

# Security
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRATION_MS=86400000

# Admin account (created once on first startup if admins table is empty)
ADMIN_AUTO_CREATE=true
ADMIN_EMAIL=admin@quickbooks.local
ADMIN_PASSWORD=change-me
ADMIN_NAME=Platform Admin

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:9091,http://localhost:9092
